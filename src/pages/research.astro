---
// src/pages/research.astro
import BaseLayout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. 获取所有 research 项目
const allProjects = await getCollection('research');
// 按日期倒序 (最新的在前面)
const sortedProjects = allProjects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout pageTitle="Research | Jingyuan XU">
  <section class="max-w-5xl mx-auto mb-16 px-4">
    <h1 class="text-3xl font-serif font-bold text-slate-900 mb-2 text-center">
      Research Projects
    </h1>
    <p class="text-slate-500 text-center mb-16 text-sm">
      Selected research works and publications.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
      
      {sortedProjects.map((project) => (
        <a 
          href={`/research/${project.slug}`} 
          class="group block bg-white rounded-xl border border-slate-200 overflow-hidden hover:shadow-lg hover:border-blue-300 transition duration-300 flex flex-col h-full"
        >
          
          <div class="w-full aspect-video overflow-hidden bg-slate-100 relative">
            <img 
              src={project.data.cover} 
              alt={project.data.title} 
              class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
            />
            
            {project.data.status && (
              <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm text-xs font-bold px-2 py-1 rounded shadow-sm text-slate-700">
                {project.data.status}
              </div>
            )}
          </div>

          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl font-serif font-bold text-slate-900 mb-2 group-hover:text-blue-700 transition">
              {project.data.title}
            </h3>
            
            {project.data.venue && (
              <p class="text-xs font-mono text-slate-500 mb-3 border-b border-slate-100 pb-2">
                {project.data.venue}
              </p>
            )}

            <p class="text-slate-600 text-sm leading-relaxed mb-4 flex-1">
              {project.data.description}
            </p>

            <div class="text-blue-600 text-sm font-medium flex items-center gap-1 group-hover:gap-2 transition-all">
              View Project <span class="transition-transform group-hover:translate-x-1">→</span>
            </div>
          </div>
          
        </a>
      ))}

    </div>
  </section>
</BaseLayout>
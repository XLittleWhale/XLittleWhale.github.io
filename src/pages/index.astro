---
import BaseLayout from '../layouts/Layout.astro';

const coverData = {
  imgUrl: "/images/cover.jpg", 
  quote: "\"Panta Rhei\", Play it Cool.",
  explanation: "by Vincent van Gogh depicts something like the quantum turbulence in a superfluid night sky.",
  author: "萬物皆流，獨奏冰絃"
};

const profile = {
  name: "Jingyuan XU",
  title: "Ph.D. Candidate",
  institution: "School of Mechanics and Engineering Science, Peking University",
  email: "cryowhale@zju.edu.cn",
  links: [
    { name: "Google Scholar", url: "#" },
    { name: "GitHub", url: "https://github.com/XLittleWhale" },
    { name: "LinkedIn", url: "https://www.linkedin.com/in/jingyuan-xu-7269291b3/" }
  ]
};

const education = [
  { 
    date: "2026-now", 
    content: "Ph.D. in Fluid Dynamics, Peking University", 
    logo: "/images/pku_logo.png" 
  },
  { 
    date: "2022-2026", 
    content: "B.S. in Cryogenic Engineering, Zhejiang University", 
    logo: "/images/zju_logo.png" 
  },
  { 
    date: "2019-2022", 
    content: "Chengdu No.7 High School", 
    logo: "/images/cdqz_logo.png" 
  },
];

const publications = [
  {
    title: "Understanding Large Language Models in Academic Contexts",
    authors: "San Zhang, Li Si, Wang Wu",
    venue: "NeurIPS 2024",
    links: [
      { text: "[PDF]", url: "#" },
      { text: "[Code]", url: "#" }
    ]
  },
  {
    title: "A Novel Approach to Static Site Generation",
    authors: "San Zhang, Astro Team",
    venue: "ICSE 2023",
    links: [
      { text: "[PDF]", url: "#" }
    ]
  }
];
---

<BaseLayout pageTitle={`${profile.name} - Homepage`}>
  
  <div class="relative w-full h-48 sm:h-64 mb-12 rounded-2xl overflow-hidden shadow-sm group">
    
    <img 
      src={coverData.imgUrl} 
      alt="Cover" 
      class="w-full h-full object-cover transition duration-700 group-hover:scale-105"
    />
    
    <div class="absolute inset-0 bg-black/30 flex flex-col items-center justify-center p-6 text-center">
      
      <p class="text-white text-xl sm:text-2xl font-serif italic font-medium tracking-wide drop-shadow-md">
        {coverData.quote}
      </p>

      {coverData.author && (
        <p class="text-white/80 text-xl mt-2 font-sans font-light tracking-wider  mb-2">
          {coverData.author}
        </p>
      )}

      <p class="w-128 text-white text-0.5xl font-sans font-light tracking-wide drop-shadow-md">
        <i>"The Starry Night"</i> {coverData.explanation}
      </p>
      
      
      
    </div>
  </div>

  <section class="flex flex-col gap-8 items-center text-center mb-16">
    
    <div class="w-32 h-32 sm:w-48 sm:h-48 flex-shrink-0">
      <img 
        src="/avatar.jpg" 
        alt="Profile Picture" 
        class="w-full h-full object-cover rounded-full shadow-lg hover:scale-105 transition duration-300"
      />
    </div>

    <div class="flex-1">
      <h1 class="text-3xl font-serif font-bold text-slate-900 mb-2">{profile.name}</h1>
      <p class="text-slate-600 text-lg mb-1">{profile.title}</p>
      <p class="text-slate-600 mb-4">{profile.institution}</p>
      
      <div class="flex flex-wrap justify-center gap-3 text-sm text-blue-700 mb-6">
        <a href={`mailto:${profile.email}`} class="hover:underline">{profile.email}</a>
        {profile.links.map(link => (
          <span>/</span>
          <a href={link.url} class="hover:underline font-medium">{link.name}</a>
        ))}
      </div>

      <div class="prose prose-slate text-slate-600 leading-relaxed mx-auto text-center">
        <p>
          My research interests lie in <strong>Superfluid, Quantum Turbulence</strong>, and <strong>AI/QC for Fluid Dynamics</strong>.
        </p>
        <p>
          Currently, I am a PhD candidate of Fluid Dynamics, supervised by <a href="http://www2.coe.pku.edu.cn/subpaget.asp?id=489" class="text-blue-600 hover:underline">Professor Yue Yang</a>, Peking University.
        </p>
        <p>
          In my previous time of Zhejiang University, I studied Cryogenic Engineering, Physics and Mathematics, supervised by <a href="https://person.zju.edu.cn/srbao" class="text-blue-600 hover:underline">Shiran Bao</a> and <a href="https://person.zju.edu.cn/shengzecai" class="text-blue-600 hover:underline">Shengze Cai</a>.
        </p>
      </div>
    </div>
  </section>

  <section class="mb-12 text-center">
    <h2 class="text-xl font-serif font-bold border-b border-slate-200 pb-2 mb-4 text-center">Education</h2>
    
    <ul class="space-y-8 max-w-2xl mx-auto text-left">
      {education.map(item => (
        <li class="flex items-center gap-4 text-slate-700 text-sm sm:text-base">
          
          <span class="w-24 flex-shrink-0 font-mono text-slate-400 text-right">{item.date}</span>
          
          <span class="flex-1">{item.content}</span>
          
          {item.logo && (
            <img 
              src={item.logo} 
              alt="Logo" 
              class="w-12 h-12 object-contain opacity-80 hover:opacity-100 transition" 
            />
          )}
        </li>
      ))}
    </ul>
  </section>


  <!-- <section class="mb-12 text-center">
    <h2 class="text-xl font-serif font-bold border-b border-slate-200 pb-2 mb-4 text-center">Selected Publications</h2>
    <div class="space-y-6">
      {publications.map(pub => (
        <div class="group flex flex-col items-center">
          <h3 class="font-semibold text-slate-900 group-hover:text-blue-600 transition">
            {pub.title}
          </h3>
          <p class="text-slate-600 text-sm mt-1">
            {pub.authors.replace("San Zhang", "<b>San Zhang</b>").split(",").map((part, index, array) => (
                <span set:html={part + (index < array.length - 1 ? ", " : "")} />
            ))}
          </p>
          <div class="flex justify-center gap-3 text-sm mt-1 items-center">
            <span class="italic text-slate-500">{pub.venue}</span>
            {pub.links.map(link => (
              <a href={link.url} class="text-blue-700 hover:underline font-mono text-xs border border-blue-200 px-1 rounded hover:bg-blue-50">
                {link.text}
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section> -->

</BaseLayout>



